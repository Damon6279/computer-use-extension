def run_calibrate(args):
    """Show display scale factor and test coordinate conversion."""
    scale = get_display_scale()
    pos = native_mouse_position()

    # Get screen resolution info
    screen_pts = {}
    screen_px = {}
    try:
        r = subprocess.run(
            ["osascript", "-e", "tell app \"Finder\" to get bounds of window of desktop"],
            capture_output=True, text=True, timeout=5
        )
        if r.returncode == 0:
            parts = [int(x.strip()) for x in r.stdout.strip().split(",")]
            screen_pts = {"width": parts[2] - parts[0], "height": parts[3] - parts[1]}
    except Exception:
        pass

    try:
        import tempfile
        tmp = tempfile.NamedTemporaryFile(suffix=".png", delete=False)
        tmp.close()
        subprocess.run(["screencapture", "-x", tmp.name], timeout=5, capture_output=True)
        try:
            from PIL import Image
            px_size = Image.open(tmp.name).size
            screen_px = {"width": px_size[0], "height": px_size[1]}
        except ImportError:
            pass
        os.unlink(tmp.name)
    except Exception:
        pass

    result = {
        "status": "ok",
        "display_scale": scale,
        "is_retina": scale >= 2.0,
        "screen_points": screen_pts,
        "screen_pixels": screen_px,
        "mouse_position_points": pos if pos.get("status") == "ok" else None,
    }

    if screen_pts and screen_px:
        result["note"] = (
            f"Screen is {screen_px.get('width')}x{screen_px.get('height')} px "
            f"= {screen_pts.get('width')}x{screen_pts.get('height')} pts "
            f"(scale {scale}x). Use --ocr on click/mouse to auto-convert OCR pixel coords."
        )

    json_output(result)


def run_start_chrome(args):
    """Launch Chrome with remote debugging port. Keeps existing instance."""
    port = args.port or CDP_PORT
    try:
        # Check if Chrome is already running with debug port
        tabs = cdp_discover_tabs()
        if tabs:
            json_output({"status": "ok", "message": f"Chrome already running with CDP on port {port}", "tabs": len(tabs)})
            return

        # Launch Chrome with debug port
        chrome_paths = [
            "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
        ]
        chrome = None
        for p in chrome_paths:
            if os.path.exists(p):
                chrome = p
                break

        if not chrome:
            json_output({"status": "failed", "error": "Chrome not found"})
            return

        # Use open -n to avoid opening a new instance if already running
        subprocess.Popen([
            "open", "-a", "Google Chrome", "-n", "--args",
            f"--remote-debugging-port={port}",
            "--no-first-run",
        ])
        json_output({"status": "ok", "message": f"Chrome launched with CDP on port {port}"})
    except Exception as e:
        json_output({"status": "failed", "error": str(e)})


def run_cdp_click(args):
    """CDP click by coordinates or selector."""
    if hasattr(args, 'selector') and args.selector:
        # Find element position via Runtime.evaluate
        js = """(function(){
            var el = document.querySelector(SEL);
            if (!el) return {error: 'not found'};
            var r = el.getBoundingClientRect();
            return {x: Math.round(r.x + r.width/2), y: Math.round(r.y + r.height/2), tag: el.tagName, text: (el.innerText||'').trim().substring(0,60)};
        })()""".replace("SEL", json.dumps(args.selector))
        eval_result = cdp_send("Runtime.evaluate", {
            "expression": js,
            "returnByValue": True
        })
        if eval_result["status"] != "ok":
            json_output(eval_result)
            return
        pos = eval_result["result"].get("result", {}).get("value", {})
        if pos.get("error"):
            json_output({"status": "failed", "error": pos["error"]})
            return
        x, y = pos["x"], pos["y"]
        result = cdp_send("Input.dispatchMouseEvent", {
            "type": "mouseMoved", "x": x, "y": y, "button": "left"
        })
        result = cdp_send("Input.dispatchMouseEvent", {
            "type": "mousePressed", "x": x, "y": y, "button": "left", "clickCount": 1
        })
        result = cdp_send("Input.dispatchMouseEvent", {
            "type": "mouseReleased", "x": x, "y": y, "button": "left", "clickCount": 1
        })
        json_output({"status": "ok", "method": "cdp", "selector": args.selector, "x": x, "y": y, "element": pos})
    else:
        # Direct coordinates
        result = cdp_send("Input.dispatchMouseEvent", {
            "type": "mousePressed", "x": args.x, "y": args.y, "button": "left", "clickCount": 1
        })
        result = cdp_send("Input.dispatchMouseEvent", {
            "type": "mouseReleased", "x": args.x, "y": args.y, "button": "left", "clickCount": 1
        })
        json_output(result)


def run_cdp_type(args):
    """CDP fill input by selector."""
    js = """(function(){
        var el = document.querySelector(SEL);
        if (!el) return {error: 'not found'};
        el.focus();
        var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set
            || Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value').set;
        if (setter) setter.call(el, VAL);
        el.dispatchEvent(new Event('input', {bubbles: true}));
        el.dispatchEvent(new Event('change', {bubbles: true}));
        return {filled: true, value: VAL_TRUNC};
    })()""".replace("SEL", json.dumps(args.selector)).replace("VAL", json.dumps(args.text)).replace("VAL_TRUNC", json.dumps(args.text[:100]))
    result = cdp_send("Runtime.evaluate", {
        "expression": js,
        "returnByValue": True
    })
    json_output(result)


def run_cdp_eval(args):
    """CDP evaluate JavaScript."""
    result = cdp_send("Runtime.evaluate", {"expression": args.expression, "returnByValue": True})
    json_output(result)


def run_cdp_interactive(args):
    # Get interactive elements via CDP evaluate
    js = """
    (function(){
        var sel='button,a,input,textarea,select,[role="button"],[role="checkbox"],[role="radio"]';
        var els=document.querySelectorAll(sel);
        var out=[];
        for(var i=0;i<els.length&&i<200;i++){
            var r=els[i].getBoundingClientRect();
            if(r.width>0&&r.height>0&&r.x>=0&&r.y>=0){
                out.push({
                    index:i,tag:els[i].tagName,
                    text:(els[i].innerText||'').trim().substring(0,80),
                    type:(els[i].type||''),id:(els[i].id||''),
                    x:Math.round(r.x),y:Math.round(r.y),
                    w:Math.round(r.width),h:Math.round(r.height),
                    cx:Math.round(r.x+r.width/2),cy:Math.round(r.y+r.height/2)
                });
            }
        }
        return out;
    })()
    """
    result = cdp_send("Runtime.evaluate", {"expression": js, "returnByValue": True})
    json_output(result)


def run_cdp_screenshot(args):
    result = cdp_send("Page.captureScreenshot", {"format": "png"})
    if result.get("status") == "ok" and result.get("result", {}).get("data"):
        data = result["result"]["data"]
        path = str(SCREENSHOT_DIR / f"cu_cdp_{int(time.time()*1000)}.png")
        with open(path, "wb") as f:
            f.write(base64.b64decode(data))
        json_output({"status": "ok", "path": path, "size": len(data)})
    else:
        json_output(result)


def run_cdp_file(args):
    """Set file input using CDP with proper nodeId resolution."""
    selector = args.selector
    file_path = args.path

    # Step 1: Get document root
    doc = cdp_send("DOM.getDocument")
    if doc["status"] != "ok":
        json_output(doc)
        return
    doc_node_id = doc["result"]["root"]["nodeId"]

    # Step 2: Query for the file input
    q = cdp_send("DOM.querySelector", {"nodeId": doc_node_id, "selector": selector})
    if q["status"] != "ok":
        json_output(q)
        return
    node_id = q["result"]["nodeId"]
    if not node_id or node_id == 0:
        json_output({"status": "failed", "error": f"Element not found: {selector}"})
        return

    # Step 3: Set the files
    r = cdp_send("DOM.setFileInputFiles", {"nodeId": node_id, "files": [file_path]})
    json_output(r)


def run_cdp_tabs(args):
    result = cdp_process_tabs(args.verbose)
    json_output(result)


def run_chrome_js(args):
    """Execute JS in Chrome via CDP WebSocket — no hanging on stuck pages."""
    result = chrome_js(
        expression=args.expression,
        timeout_sec=args.timeout,
        return_by_value=not args.no_return,
        await_promise=args.await_promise,
    )
    json_output(result)


def run_step(args):
    """Execute a step: action → wait → screenshot (for agent verification loop)."""
    action = args.action or "click"
    selector = args.selector
    value = args.value

    if not selector and action not in ("screenshot", "wait"):
        json_output({"status": "failed", "error": "--selector required for this action"})
        return

    result = {"step": args.description, "action": action, "status": "ok", "actions": []}

    try:
        if action == "click" and selector:
            # Try CDP first (if websocket-client available)
            try:
                import websocket  # noqa: F401
                r = run_cdp_click_raw(args)
                result["actions"].append({"method": "cdp", "selector": selector, "x": r.get("x"), "y": r.get("y")})
            except ImportError:
                # Fallback to native click: get element position first via JS eval
                r = {"status": "failed", "error": "CDP not available"}

        elif action == "fill" and selector and value:
            result["actions"].append({"method": "cdp", "selector": selector})
            # Use CDP fill
            js = """(function(){
                var el = document.querySelector(SEL);
                if (!el) return {error: 'not found'};
                el.focus();
                var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set
                    || Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value').set;
                if (setter) setter.call(el, VAL);
                el.dispatchEvent(new Event('input', {bubbles: true}));
                el.dispatchEvent(new Event('change', {bubbles: true}));
                return {filled: true};
            })()""".replace("SEL", json.dumps(selector)).replace("VAL", json.dumps(value))
            cdp_send("Runtime.evaluate", {"expression": js, "returnByValue": True})

        elif action == "screenshot":
            result["actions"].append({"method": "native"})

        elif action == "wait":
            time.sleep(float(value or 1))
            result["actions"].append({"method": "wait", "seconds": float(value or 1)})

    except Exception as e:
        result["status"] = "failed"
        result["error"] = str(e)

    # Always take a verification screenshot
    wait_ms = int(args.wait) if args.wait else 800
    time.sleep(wait_ms / 1000)

    if args.ocr:
        ocr_result = native_ocr()
        result["screenshot"] = ocr_result
    else:
        ss = native_screenshot()
        result["screenshot"] = ss

    json_output(result)


def run_cdp_click_raw(args):
    """CDP click helper used by run_step."""
    js = """(function(){
        var el = document.querySelector(SEL);
        if (!el) return {error: 'not found'};
        var r = el.getBoundingClientRect();
        return {x: Math.round(r.x + r.width/2), y: Math.round(r.y + r.height/2), tag: el.tagName};
    })()""".replace("SEL", json.dumps(args.selector))
    eval_result = cdp_send("Runtime.evaluate", {"expression": js.strip(), "returnByValue": True})
    if eval_result["status"] != "ok":
        return {"error": eval_result.get("error")}
    pos = eval_result["result"].get("result", {}).get("value", {})
    if pos.get("error"):
        return {"error": pos["error"]}
    x, y = pos["x"], pos["y"]
    cdp_send("Input.dispatchMouseEvent", {"type": "mousePressed", "x": x, "y": y, "button": "left", "clickCount": 1})
    cdp_send("Input.dispatchMouseEvent", {"type": "mouseReleased", "x": x, "y": y, "button": "left", "clickCount": 1})
    return {"x": x, "y": y}


def run_serve(args):
    """Start HTTP server for agent integration."""
    port = args.port or 9090
    host = args.host or "127.0.0.1"
    no_auth = args.no_auth
    token = args.token or os.environ.get("CU_TOKEN") or ""

    if not token and not no_auth:
        print("ERROR: --token <value> or CU_TOKEN env var required for security.", file=sys.stderr)
        print("  Use --no-auth for local-only development (not recommended).", file=sys.stderr)
        print(json.dumps({"status": "failed", "error": "Token required, set CU_TOKEN or --token"}))
        return

    if no_auth:
        print("WARNING: Running without authentication. Only use on localhost.", file=sys.stderr)

    print(json.dumps({
        "status": "ok",
        "message": f"Server starting on {host}:{port}" + (" (authenticated)" if token else " (no auth)"),
        "endpoints": {
            "POST /execute": "Run a command (same as CLI args, in JSON body)",
            "GET /health": "Health check (no auth)",
            "POST /step": "Execute step → screenshot → return result+ocr"
        }
    }), file=sys.stderr)

    from http.server import HTTPServer, BaseHTTPRequestHandler

    class CUHandler(BaseHTTPRequestHandler):
        def log_message(self, format, *args):
            pass

        def _send_json(self, data, status=200):
            body = json.dumps(data, ensure_ascii=False).encode("utf-8")
            self.send_response(status)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            # Restrict CORS to loopback
            origin = self.headers.get("Origin", "")
            allowed = any(origin.startswith(p) for p in [
                "http://127.0.0.1:", "http://localhost:",
                "chrome-extension://"
            ])
            if allowed or not origin:
                self.send_header("Access-Control-Allow-Origin", origin or "*")
                self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
                self.send_header("Access-Control-Allow-Headers", "Authorization, Content-Type")
            self.end_headers()
            self.wfile.write(body)

        def _check_auth(self):
            if not token:
                return True
            if self.headers.get("Authorization", "") == f"Bearer {token}":
                return True
            self._send_json({"status": "failed", "error": "Unauthorized"}, 401)
            return False

        def do_OPTIONS(self):
            self._send_json({"status": "ok"})

        def do_GET(self):
            if self.path == "/health":
                self._send_json({"status": "ok", "service": "computer-use", "version": "1.0.0"})
            elif self.path == "/status":
                if not self._check_auth():
                    return
                self._send_json({
                    "status": "ok",
                    "cliclick": shutil.which("cliclick") is not None,
                    "ocr": os.path.exists(OCR_BIN),
                    "chrome_cdp": isinstance(cdp_discover_tabs(), list),
                    "cdp_port": CDP_PORT,
                })
            else:
                self._send_json({"status": "failed", "error": "Not found"}, 404)

        def do_POST(self):
            if not self._check_auth():
                return
            try:
                length = int(self.headers.get("Content-Length", 0))
                body = self.rfile.read(length).decode("utf-8") if length else "{}"
                data = json.loads(body) if body.strip() else {}
            except (json.JSONDecodeError, ValueError):
                self._send_json({"status": "failed", "error": "Invalid JSON"}, 400)
                return

            if self.path == "/execute":
                self._send_json(self._handle_execute(data))
            elif self.path == "/step":
                self._send_json(self._handle_step(data))
            else:
                self._send_json({"status": "failed", "error": "Not found"}, 404)

        def _handle_execute(self, data):
            """Execute a command. data: {command, args...}"""
            cmd = data.get("command", "")
            if cmd == "screenshot":
                return native_ocr() if data.get("ocr") else native_screenshot()
            elif cmd == "ocr":
                return native_ocr(data.get("path"))
            elif cmd == "tree":
                return native_accessibility_tree()
            elif cmd == "click":
                x, y = data.get("x"), data.get("y")
                if data.get("ocr"):
                    scale = get_display_scale()
                    x = px_to_pt(x, scale)
                    y = px_to_pt(y, scale)
                return native_mouse_click(x, y)
            elif cmd == "type":
                return native_type_text(data.get("text", ""))
            elif cmd == "key":
                return native_key_press(data.get("shortcut", ""))
            elif cmd == "scroll":
                return native_scroll(data.get("dx", 0), data.get("dy", 3))
            elif cmd == "position":
                return native_mouse_position()
            elif cmd == "mouse":
                x, y = data.get("x"), data.get("y")
                if data.get("ocr"):
                    scale = get_display_scale()
                    x = px_to_pt(x, scale)
                    y = px_to_pt(y, scale)
                return native_mouse_move(x, y)
            elif cmd == "cdp-tabs":
                return cdp_process_tabs()
            elif cmd == "cdp-file":
                selector = data.get("selector", "")
                filepath = data.get("path", "")
                if not selector or not filepath:
                    return {"status": "failed", "error": "selector and path required"}
                doc = cdp_send("DOM.getDocument")
                if doc["status"] != "ok":
                    return doc
                q = cdp_send("DOM.querySelector", {"nodeId": doc["result"]["root"]["nodeId"], "selector": selector})
                if q["status"] != "ok" or not q["result"].get("nodeId"):
                    return {"status": "failed", "error": f"Element not found: {selector}"}
                return cdp_send("DOM.setFileInputFiles", {"nodeId": q["result"]["nodeId"], "files": [filepath]})
            elif cmd == "cdp-eval":
                return cdp_send("Runtime.evaluate", {"expression": data.get("expression", ""), "returnByValue": True})
            else:
                return {"status": "failed", "error": f"Unknown command: {cmd}"}

        def _handle_step(self, data):
            """Execute a step with screenshot verification."""
            action = data.get("action", "click")
            selector = data.get("selector")
            value = data.get("value")
            wait_ms = int(data.get("wait", 800))
            do_ocr = data.get("ocr", True)
            result = {"action": action, "status": "ok", "started_at": time.time()}

            try:
                if action == "click" and selector:
                    try:
                        import websocket  # noqa: F401
                        js = """(function(){
                            var el = document.querySelector(SEL);
                            if (!el) return {error: 'not found'};
                            var r = el.getBoundingClientRect();
                            return {x: Math.round(r.x + r.width/2), y: Math.round(r.y + r.height/2)};
                        })()""".replace("SEL", json.dumps(selector))
                        pr = cdp_send("Runtime.evaluate", {"expression": js, "returnByValue": True})
                        if pr.get("status") == "ok":
                            pos = pr["result"].get("result", {}).get("value", {})
                            if pos.get("x"):
                                cdp_send("Input.dispatchMouseEvent", {"type": "mousePressed", "x": pos["x"], "y": pos["y"], "button": "left", "clickCount": 1})
                                cdp_send("Input.dispatchMouseEvent", {"type": "mouseReleased", "x": pos["x"], "y": pos["y"], "button": "left", "clickCount": 1})
                                result.update(method="cdp", x=pos["x"], y=pos["y"])
                    except ImportError:
                        pass
                elif action == "fill" and selector and value:
                    js = """(function(){
                        var el = document.querySelector(SEL);
                        if (!el) return {error: 'not found'};
                        el.focus();
                        var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set
                            || Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value').set;
                        if (setter) setter.call(el, VAL);
                        el.dispatchEvent(new Event('input', {bubbles: true}));
                        el.dispatchEvent(new Event('change', {bubbles: true}));
                        return {filled: true};
                    })()""".replace("SEL", json.dumps(selector)).replace("VAL", json.dumps(value))
                    cdp_send("Runtime.evaluate", {"expression": js, "returnByValue": True})
                    result["method"] = "cdp"
                elif action == "wait":
                    time.sleep(float(value or 1))
                    result["waited"] = float(value or 1)
            except Exception as e:
                result.update(status="failed", error=str(e))

            time.sleep(wait_ms / 1000)
            ss = native_ocr() if do_ocr else native_screenshot()
            result["screenshot"] = ss
            result["elapsed"] = round(time.time() - result["started_at"], 2)
            del result["started_at"]
            return result

    server = HTTPServer((host, port), CUHandler)
    print(f"Listening on http://{host}:{port}", file=sys.stderr)
    print(f"Try: curl http://{host}:{port}/health", file=sys.stderr)
    print(file=sys.stderr)

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down...", file=sys.stderr)
        server.shutdown()



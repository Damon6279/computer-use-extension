# ── Paths ──────────────────────────────────────────────────────────

PROJECT_DIR = Path(__file__).resolve().parent.parent
NATIVE_HOST_DIR = PROJECT_DIR / "native-host"
OCR_BIN = str(NATIVE_HOST_DIR / "ocr")
CLICKLICK = shutil.which("cliclick") or "/opt/homebrew/bin/cliclick"
MAC_USE = os.path.expanduser("~/.local/bin/mac-use")
SCREENSHOT_DIR = Path(os.path.expanduser("~/.cache/mac-use-screenshots"))
SCREENSHOT_DIR.mkdir(parents=True, exist_ok=True)

CDP_PORT = int(os.environ.get("CU_CDP_PORT", "9222"))


# ── Native Operations ─────────────────────────────────────────────

def native_screenshot(window_name=None):
    """Take a screenshot via screencapture.

    Args:
        window_name: If given, capture only this app's window (e.g. "Google Chrome").
                     If None, capture full screen.

    Window capture uses bounds-based approach: gets the window position/size
    via AppleScript, then captures that screen region with -R.
    This avoids needing CGWindowIDs (which require PyObjC or Swift to resolve).
    """
    ts = int(time.time() * 1000)
    path = str(SCREENSHOT_DIR / f"cu_{ts}.png")

    if window_name:
        # Get window bounds: left, top, right, bottom
        script = f'tell app "{window_name}" to get bounds of window 1'
        r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=5)
        if r.returncode != 0 or not r.stdout.strip():
            return {"status": "failed", "error": f"No window found for app: {window_name}"}
        parts = [int(x.strip()) for x in r.stdout.strip().split(",")]
        if len(parts) != 4:
            return {"status": "failed", "error": f"Unexpected bounds format: {r.stdout.strip()}"}
        left, top, right, bottom = parts
        w, h = right - left, bottom - top
        subprocess.run(
            ["screencapture", "-R", f"{left},{top},{w},{h}", path],
            timeout=10, capture_output=True
        )
    else:
        subprocess.run(["screencapture", "-x", path], timeout=10, capture_output=True)

    if not os.path.exists(path):
        return {"status": "failed", "error": "screencapture failed"}
    scale = get_display_scale()
    return {"status": "ok", "path": path, "window": window_name or "fullscreen", "scale": scale}


def native_ocr(image_path=None, window_name=None):
    """Run Apple Vision OCR on an image. Takes screenshot if no path given.

    Args:
        image_path: Path to an existing image, or None to take a screenshot first.
        window_name: If taking a screenshot, app window to capture (None = full screen).
    """
    if image_path:
        path = image_path
    else:
        result = native_screenshot(window_name)
        if result["status"] != "ok":
            return result
        path = result["path"]

    if not os.path.exists(path):
        return {"status": "failed", "error": f"Image not found: {path}"}

    try:
        r = subprocess.run([OCR_BIN, path], capture_output=True, text=True, timeout=30)
        if r.returncode != 0:
            return {"status": "failed", "error": r.stderr.strip() or r.stdout.strip()}
        data = json.loads(r.stdout)
        # Add pixel-level coordinates for convenience
        iw, ih = data["imageWidth"], data["imageHeight"]
        for block in data["blocks"]:
            block["px"] = round(block["x"] * iw)
            block["py"] = round((1 - block["y"] - block["h"]) * ih)
            block["pw"] = round(block["w"] * iw)
            block["ph"] = round(block["h"] * ih)
        scale = get_display_scale()
        return {
            "status": "ok",
            "path": path,
            "imageWidth": iw,
            "imageHeight": ih,
            "scale": scale,
            "blocks": data["blocks"],
            "window": window_name or "fullscreen"
        }
    except json.JSONDecodeError as e:
        return {"status": "failed", "error": f"JSON parse: {e}"}
    except Exception as e:
        return {"status": "failed", "error": str(e)}


def get_display_scale():
    """Get the main screen's backing scale factor (2.0 for Retina, 1.0 for standard).

    Uses `system_profiler` or `screen` query to detect Retina.
    Falls back to `defaults` or `screencapture` comparison.
    """
    try:
        r = subprocess.run(
            ["system_profiler", "SPDisplaysDataType", "-json"],
            capture_output=True, text=True, timeout=5
        )
        if r.returncode == 0:
            data = json.loads(r.stdout)
            displays = data.get("SPDisplaysDataType", [])
            for d in displays:
                if d.get("spdisplays_retina") == "spdisplays_retina-yes":
                    return 2.0
    except Exception:
        pass

    # Fallback: compare point-based vs pixel-based screen size
    try:
        r = subprocess.run(
            ["osascript", "-e", "tell app \"Finder\" to get bounds of window of desktop"],
            capture_output=True, text=True, timeout=5
        )
        if r.returncode == 0:
            parts = [int(x.strip()) for x in r.stdout.strip().split(",")]
            pt_w = parts[2] - parts[0]
            # screencapture on Retina gives twice the points
            import tempfile
            tmp = tempfile.NamedTemporaryFile(suffix=".png", delete=False)
            tmp.close()
            subprocess.run(["screencapture", "-x", tmp.name], timeout=5, capture_output=True)
            try:
                from PIL import Image
                px_w = Image.open(tmp.name).size[0]
                scale = round(px_w / pt_w, 1)
                return scale
            except ImportError:
                pass
            finally:
                os.unlink(tmp.name)
    except Exception:
        pass

    return 1.0


def px_to_pt(value, scale=None):
    """Convert pixel value to point value using the display scale."""
    if scale is None:
        scale = get_display_scale()
    return round(value / scale)


def native_accessibility_tree():
    """Get AX UI element tree of the frontmost app via System Events."""
    script = '''
tell application "System Events"
    set frontApp to name of first process whose frontmost is true
end tell
tell application "System Events"
    tell process frontApp
        set windowCount to count of windows
        if windowCount = 0 then return "{\\"windows\\":0}"
        set allUI to every UI element of window 1
        set output to ""
        repeat with el in allUI
            try
                set r to role of el
                try
                    set d to description of el
                end try
                try
                    set t to title of el
                end try
                set p to position of el
                set sz to size of el
                set output to output & r & "|" & t & "|" & d & "|" & (item 1 of p) & "," & (item 2 of p) & "," & (item 1 of sz) & "x" & (item 2 of sz) & "
"
                end try
            end repeat
        return output
    end tell
end tell
'''
    r = subprocess.run(["osascript", "-e", script], capture_output=True, text=True, timeout=15)
    if r.returncode != 0:
        return {"status": "failed", "error": r.stderr.strip()}

    elements = []
    for line in r.stdout.strip().split("\n"):
        if not line.strip() or line.strip() == '{"windows":0}':
            continue
        parts = line.split("|", 3)
        if len(parts) == 4:
            role, title, desc, pos = parts
            try:
                wp = pos.replace("x", ",").split(",")
                elements.append({
                    "role": role,
                    "title": title if title != "missing value" else "",
                    "description": desc if desc != "missing value" else "",
                    "x": int(wp[0]), "y": int(wp[1]), "w": int(wp[2]), "h": int(wp[3])
                })
            except (ValueError, IndexError):
                pass

    return {"status": "ok", "elements": elements, "count": len(elements)}


def native_mouse_click(x, y):
    subprocess.run([CLICKLICK, f"c:{x},{y}"], timeout=5, capture_output=True)
    return {"status": "ok", "action": "click", "x": x, "y": y}


def native_mouse_move(x, y):
    subprocess.run([CLICKLICK, f"m:{x},{y}"], timeout=5, capture_output=True)
    return {"status": "ok", "action": "move", "x": x, "y": y}


def native_mouse_position():
    r = subprocess.run([CLICKLICK, "p"], capture_output=True, text=True, timeout=5)
    if r.returncode == 0 and r.stdout.strip():
        parts = r.stdout.strip().split(",")
        return {"status": "ok", "x": int(parts[0]), "y": int(parts[1])}
    return {"status": "failed", "error": r.stderr.strip()}


def native_scroll(dx, dy, x=None, y=None):
    args = [CLICKLICK]
    if dx == 0:
        args.append(f"w:{dy}")
    else:
        # cliclick doesn't support horizontal scroll directly, use AppleScript
        ascript = f'tell application "System Events" to key code 123'
        subprocess.run(["osascript", "-e", ascript], timeout=5)
        return {"status": "ok", "note": "horizontal scroll simulated via arrow key", "dx": dx}

    if x is not None and y is not None:
        args.append(f"{x},{y}")
    subprocess.run(args, timeout=5, capture_output=True)
    return {"status": "ok", "dx": dx, "dy": dy}


def native_type_text(text):
    # Use clipboard paste for reliable unicode
    p = subprocess.Popen(["pbcopy"], stdin=subprocess.PIPE)
    p.communicate(text.encode("utf-8"))
    time.sleep(0.1)
    subprocess.run(
        ["osascript", "-e",
         'tell application "System Events" to keystroke "v" using {command down}'],
        timeout=5, capture_output=True
    )
    return {"status": "ok", "length": len(text), "method": "paste"}


def native_key_press(shortcut):
    parts = shortcut.lower().split("+")
    key = parts[-1]
    modifiers = parts[:-1]

    mod_map = {
        "cmd": "command down", "command": "command down",
        "ctrl": "control down", "control": "control down",
        "alt": "option down", "option": "option down",
        "shift": "shift down",
    }

    using = ""
    mods = ", ".join(m for m in [mod_map.get(m) for m in modifiers if m in mod_map] if m)
    if mods:
        using = f" using {{{mods}}}"

    special = {
        "enter": "return", "return": "return", "tab": "tab",
        "escape": "escape", "esc": "escape", "delete": "delete",
        "backspace": "delete", "space": "space", "up": "up-arrow",
        "down": "down-arrow", "left": "left-arrow", "right": "right-arrow",
    }

    if key in special:
        script = f'tell application "System Events" to keystroke {special[key]}{using}'
    else:
        script = f'tell application "System Events" to keystroke "{key}"{using}'

    subprocess.run(["osascript", "-e", script], timeout=5, capture_output=True)
    return {"status": "ok", "shortcut": shortcut}


# ── CDP Operations (Chrome DevTools Protocol) ─────────────────────

def cdp_discover_tabs():
    """Find Chrome tabs via DevTools Protocol HTTP endpoint."""
    try:
        url = f"http://localhost:{CDP_PORT}/json"
        req = urllib.request.urlopen(url, timeout=3)
        return json.loads(req.read().decode())
    except (urllib.error.URLError, ConnectionRefusedError, socket.timeout, json.JSONDecodeError) as e:
        return None


def cdp_send(method, params=None, tab_id=None, timeout_sec=10):
    """Send a CDP command via WebSocket to Chrome tab.

    Requires websocket-client: pip3 install websocket-client
    """
    try:
        import websocket
    except ImportError:
        # Return instructions if library not available
        tabs = cdp_discover_tabs()
        if not tabs:
            return {"status": "failed", "error": f"Cannot connect to Chrome at port {CDP_PORT}"}
        return {
            "status": "failed",
            "error": "websocket-client not installed",
            "install": "pip3 install websocket-client",
            "tabCount": len(tabs)
        }

    # Find the tab
    tabs = cdp_discover_tabs()
    if not tabs:
        return {"status": "failed", "error": f"Cannot connect to Chrome at port {CDP_PORT}"}

    target = None
    for t in tabs:
        if tab_id and t["id"] == tab_id:
            target = t
            break
        if not tab_id and t.get("type") == "page" and t.get("url", "").startswith("http"):
            target = t
            break
    if not target:
        target = tabs[0]

    ws_url = target["webSocketDebuggerUrl"]
    msg_id = int(time.time() * 1000)

    try:
        ws = websocket.create_connection(ws_url, timeout=timeout_sec)
        ws.send(json.dumps({"id": msg_id, "method": method, "params": params or {}}))

        # Wait for response with matching id
        start = time.time()
        while time.time() - start < timeout_sec:
            resp = json.loads(ws.recv())
            if resp.get("id") == msg_id:
                ws.close()
                if "error" in resp:
                    return {"status": "failed", "error": resp["error"].get("message", str(resp["error"]))}
                return {"status": "ok", "result": resp.get("result")}
        ws.close()
        return {"status": "failed", "error": "Response timeout"}
    except Exception as e:
        return {"status": "failed", "error": str(e)}


def cdp_process_tabs(verbose=False):
    """List and format available tabs."""
    tabs = cdp_discover_tabs()
    if not tabs:
        return {"status": "failed", "error": f"No Chrome with --remote-debugging-port={CDP_PORT}"}

    result = []
    for t in tabs:
        result.append({
            "id": t.get("id"),
            "title": t.get("title", "")[:80],
            "url": t.get("url", "")[:120],
            "type": t.get("type", "page"),
        })
    return {"status": "ok", "tabs": result, "count": len(result)}


def _osa_exec_js(js_code, timeout=15):
    """Execute JavaScript in Chrome via AppleScript, with timeout handling.

    AppleScript's execute javascript blocks when the page is stuck (Pace.js spinner,
    AJAX loading, mid-navigation). This handles that by catching TimeoutExpired,
    reloading the tab, and retrying once.
    """
    b64 = base64.b64encode(js_code.encode()).decode()
    as_src = (
        'tell application "Google Chrome"\n'
        'set js to do shell script "echo {b64} | base64 -d"\n'
        'set result to execute active tab of window 1 javascript js\n'
        'return result\n'
        'end tell'
    )

    try:
        proc = subprocess.run(['osascript', '-e', as_src], capture_output=True, text=True, timeout=timeout)
        if proc.returncode != 0:
            return {"status": "failed", "error": proc.stderr.strip() or proc.stdout.strip()}
        return {"status": "ok", "result": {"value": proc.stdout.strip()}}
    except subprocess.TimeoutExpired:
        # Page is stuck — reload and retry once
        subprocess.run(
            ['osascript', '-e', 'tell app "Google Chrome" to reload active tab of window 1'],
            timeout=5, capture_output=True
        )
        time.sleep(5)
        try:
            proc = subprocess.run(['osascript', '-e', as_src], capture_output=True, text=True, timeout=timeout)
            if proc.returncode == 0:
                return {"status": "ok", "result": {"value": proc.stdout.strip()}}
            return {"status": "failed", "error": proc.stderr.strip()}
        except subprocess.TimeoutExpired:
            return {"status": "failed", "error": "AppleScript timeout after reload — page still stuck"}


def chrome_js(expression, timeout_sec=10, return_by_value=True, await_promise=False, native_fallback=True):
    """Execute JavaScript in Chrome via CDP, with AppleScript fallback.

    Tries CDP WebSocket first (configurable timeout, no hanging).
    If CDP is not available, falls back to AppleScript with auto-reload recovery.
    """
    params = {
        "expression": expression,
        "returnByValue": return_by_value,
    }
    if await_promise:
        params["awaitPromise"] = True
        params["timeout"] = int(timeout_sec * 1000)

    # Try CDP first
    tabs = cdp_discover_tabs()
    if tabs:
        result = cdp_send("Runtime.evaluate", params, timeout_sec=timeout_sec)
        if result.get("status") == "ok" and return_by_value:
            value = result.get("result", {}).get("result", {}).get("value")
            result["value"] = value
        result["method"] = "cdp"
        return result

    # CDP not available
    if not native_fallback:
        return {"status": "failed", "error": "Chrome CDP not available (need --remote-debugging-port=9222)",
                "method": "none"}

    # Fall back to AppleScript
    result = _osa_exec_js(expression, timeout=timeout_sec)
    if result.get("status") == "ok" and return_by_value:
        result["value"] = result.get("result", {}).get("value")
    result["method"] = "applescript"
    return result



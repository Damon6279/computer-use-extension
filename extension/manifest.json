{
  "manifest_version": 3,
  "name": "Computer Use",
  "version": "1.0.0",
  "description": "Browser automation agent with visible virtual cursor. Execute step-by-step web operations with screenshot verification.",
  "permissions": [
    "activeTab",
    "scripting",
    "nativeMessaging",
    "storage",
    "sidePanel",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/virtual-cursor.js",
        "content/dom-actions.js",
        "content/screenshot.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Computer Use",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
